VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Ixtiyoriy: Storage bucket nomi (default: product-images)
# VITE_SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

# Ixtiyoriy: products jadvalida tavsif ustuni `desc` bo‘lsa (jadval bo‘sh bo‘lganda avto aniqlanmasligi uchun)
# VITE_PRODUCTS_DESCRIPTION_COLUMN=desc

# --- Admin yaratish: npm run seed:admin (service_role ni brauzerga bermang) ---
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=
